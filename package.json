{
  "name": "ddcar-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @ddcar/shop dev",
    "build": "pnpm --filter @ddcar/shop build",
    "test": "pnpm --filter @ddcar/shop test",
